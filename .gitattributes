# Enforce LF line endings for all text files (prevents Jupyter NotJSONError on Windows)
* text=auto eol=lf

# Notebooks explicitly LF
*.ipynb text eol=lf

# Python files
*.py text eol=lf

# Markdown & config
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.env text eol=lf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pkl binary
*.joblib binary
